# ── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://syncrohws:syncrohws@localhost:5434/syncrohws
MINIO_URL=http://localhost:9000
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars!!
POWERSYNC_URL=http://localhost:8080

# ── Optional (defaults shown) ──────────────────────────────────────────────
# PORT=3000
# MINIO_BUCKET=syncrohws-files
# MINIO_ACCESS_KEY=syncrohws
# MINIO_SECRET_KEY=syncrohws_secret

# ── Owner bootstrap (Phase H) ──────────────────────────────────────────────
# Set these on first startup to seed the single owner row. After the owner
# is seeded these can be removed; subsequent restarts ignore them.
# OWNER_BOOTSTRAP_EMAIL=admin@example.com
# OWNER_BOOTSTRAP_PASSWORD=change-me-please

# ── Token TTLs (Phase H) ──────────────────────────────────────────────────
# OWNER_TOKEN_TTL_SECONDS=3600          # 1 hour
# DEVICE_TOKEN_TTL_SECONDS=31536000     # 1 year
